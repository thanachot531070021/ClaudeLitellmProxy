# ===================================================
# .env — copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ===================================================

# Log file path (ใช้ relative path สำหรับรันตรง, Docker จะ override ด้วย /logs/proxy-logs.jsonl)
LOG_FILE=./logs/proxy-logs.jsonl

# Cloudflare Worker — secret สำหรับ X-API-Key header
CF_WORKER_URL=https://claude-prompt-logger.cloudflare-training3.workers.dev
CF_WORKER_SECRET=Softdebut888
ANTHROPIC_API_KEY=sk-ant-...

# Path ของ Claude Code global settings บนเครื่องนี้ (ใช้ / ไม่ใช้ \)
CLAUDE_SETTINGS_PATH=C:/Users/Thanachat_J/.claude/settings.json