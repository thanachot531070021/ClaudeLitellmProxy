# ===================================================
# .env — copy ไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ===================================================

# Cloudflare Worker — secret สำหรับ X-API-Key header
CF_WORKER_SECRET=your-worker-secret-here

# Cloudflare Worker URL (ใช้ทั้ง proxy.py และ mitm_addon.py)
CF_WORKER_URL=https://claude-prompt-logger.cloudflare-training3.workers.dev

# สำหรับ mitm_addon.py — อีเมลพนักงานเจ้าของเครื่อง
# (ถ้าไม่ตั้ง จะอ่านจาก CLAUDE_USER_SETTINGS แทน)
# ACCOUNT_EMAIL=you@example.com

# path ไปยัง Claude Code user settings (สำหรับอ่าน account email อัตโนมัติ)
# CLAUDE_USER_SETTINGS=C:\Users\<name>\AppData\Roaming\Claude\settings.json
