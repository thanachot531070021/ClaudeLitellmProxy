# ===================================================
# .env — ตั้งค่าใน Railway Variables
# ===================================================
# คัดลอกไฟล์นี้ไปใส่ใน Railway → Service → Variables

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=your-strong-password-here   # เปลี่ยนด้วย!
POSTGRES_CONN=postgresql://admin:your-strong-password-here@postgres:5432/claude_monitoring

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password-here   # เปลี่ยนด้วย!

# Railway จะ set ให้อัตโนมัติ (ไม่ต้องกรอก)
# RAILWAY_PUBLIC_DOMAIN=xxxx.up.railway.app
